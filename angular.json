{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "",
  "projects": {
    "app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "./",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "./dist",
              "browser": "."
            },
            "browser": "index.tsx",
            "tsConfig": "tsconfig.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              },
              {
                "glob": "_redirects",
                "input": "src",
                "output": "."
              },
              {
                "glob": "_headers",
                "input": "src",
                "output": "."
              }
            ],
            "styles": ["src/styles.css"],
            "allowedCommonJsDependencies": [
              "prismjs",
              "jszip",
              "heic2any",
              "qrcode",
              "pako",
              "dijkstrajs",
              "path2d-polyfill"
            ],
            "budgets": [
              {
                "type": "initial",
                "maximumWarning": "600kb",
                "maximumError": "2mb"
              },
              {
                "type": "anyComponentStyle",
                "maximumWarning": "8kb",
                "maximumError": "32kb"
              }
            ]
          },
          "configurations": {
            "production": {
              "serviceWorker": "ngsw-config.json",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "outputHashing": "all"
            },
            "utildex": {
              "serviceWorker": "ngsw-config.json",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "outputHashing": "all",
              "outputPath": {
                "base": "./dist/utildex",
                "browser": "."
              },
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets"
                },
                {
                  "glob": "_redirects",
                  "input": "src",
                  "output": "."
                },
                {
                  "glob": "_headers",
                  "input": "src",
                  "output": "."
                },
                {
                  "glob": "*",
                  "input": "src/seo/utildex",
                  "output": "."
                }
              ]
            },
            "synedex": {
              "serviceWorker": "ngsw-config.synedex.json",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "index": {
                "input": "index.synedex.html",
                "output": "index.html"
              },
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "outputHashing": "all",
              "outputPath": {
                "base": "./dist/synedex",
                "browser": "."
              },
              "assets": [
                {
                  "glob": "**/*",
                  "input": "src/assets",
                  "output": "assets",
                  "ignore": [
                    "mcp/**"
                  ]
                },
                {
                  "glob": "_redirects",
                  "input": "src",
                  "output": "."
                },
                {
                  "glob": "_headers",
                  "input": "src",
                  "output": "."
                },
                {
                  "glob": "*",
                  "input": "src/seo/synedex",
                  "output": "."
                },
                {
                  "glob": "manifest.synedex.webmanifest",
                  "input": ".",
                  "output": "."
                }
              ],
              "fileReplacements": [
                {
                  "replace": "index.tsx",
                  "with": "index.synedex.tsx"
                },
                {
                  "replace": "app.config.ts",
                  "with": "app.config.synedex.ts"
                },
                {
                  "replace": "src/core/core-registry.ts",
                  "with": "src/core/core-registry.synedex.ts"
                },
                {
                  "replace": "src/core/tool-registry.ts",
                  "with": "src/core/tool-registry.synedex.ts"
                },
                {
                  "replace": "src/data/tool-space-registry.ts",
                  "with": "src/data/tool-space-registry.synedex.ts"
                },
                {
                  "replace": "src/services/offline-route-loaders.ts",
                  "with": "src/services/offline-route-loaders.synedex.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 3000
          },
          "configurations": {
            "production": {
              "buildTarget": "app:build:production"
            },
            "utildex": {
              "buildTarget": "app:build:utildex"
            },
            "synedex": {
              "buildTarget": "app:build:synedex"
            },
            "development": {
              "buildTarget": "app:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
