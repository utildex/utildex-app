{
  "name": "utildex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./headless": {
      "types": "./dist-headless/types/headless/index.d.ts",
      "default": "./dist-headless/headless/index.js"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ng serve",
    "dev:utildex": "ng serve --configuration=utildex --port 3000",
    "dev:synedex": "ng serve --configuration=synedex --port 3001",
    "prebuild:checks": "npm run check:integrity && npm run check:tool-ids && npm run check:app-parity && npm run format:check && npm run lint && npm run sitemap:utildex && npm run sitemap:synedex && npm run generate:mcp-manifest",
    "prebuild": "npm run prebuild:checks",
    "prebuild:utildex": "npm run prebuild:checks",
    "prebuild:synedex": "npm run prebuild:checks",
    "build": "ng build --configuration=utildex",
    "build:utildex": "ng build --configuration=utildex",
    "build:synedex": "ng build --configuration=synedex",
    "build:headless": "esbuild src/headless/index.ts --bundle --platform=node --format=esm --packages=external --target=node24 --outfile=dist-headless/headless/index.js && tsc -p tsconfig.headless.types.json",
    "preview": "ng serve --configuration=production",
    "preview:utildex": "ng serve --configuration=utildex --port 3000",
    "preview:synedex": "ng serve --configuration=synedex --port 3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:web": "vitest run -c vitest.config.ts",
    "test:headless": "vitest run -c vitest.config.headless.ts",
    "check:integrity": "tsx scripts/check-integrity.ts",
    "check:tool-ids": "tsx scripts/check-tool-ids.ts",
    "check:app-parity": "tsx scripts/check-app-parity.ts",
    "sitemap:utildex": "tsx scripts/generate-sitemap.ts --app=utildex",
    "sitemap:synedex": "tsx scripts/generate-sitemap.ts --app=synedex",
    "generate:mcp-manifest": "tsx scripts/generate-mcp-manifest.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css,scss,json,md}\""
  },
  "dependencies": {
    "@angular/common": "21.2.8",
    "@angular/compiler": "21.2.8",
    "@angular/core": "21.2.8",
    "@angular/forms": "21.2.8",
    "@angular/platform-browser": "21.2.8",
    "@angular/router": "21.2.8",
    "@angular/service-worker": "21.2.8",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@floating-ui/dom": "^1.7.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/roboto-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@types/d3": "^7.4.3",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "diff": "^5.2.0",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "12.0.0",
    "material-symbols": "^0.40.2",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.4.624",
    "prismjs": "1.30.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@analogjs/vitest-angular": "^2.5.0",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.8",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.5",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.50.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.6",
    "zone.js": "^0.16.2"
  }
}
