{
  "name": "utildex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ng serve",
    "prebuild": "tsx scripts/generate-sitemap.ts",
    "build": "ng build",
    "preview": "ng serve --configuration=production",
    "check:integrity": "tsx scripts/check-integrity.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css,scss,json,md}\""
  },
  "dependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.6",
    "@angular/service-worker": "^21.0.6",
    "@floating-ui/dom": "^1.7.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/roboto-mono": "^5.2.8",
    "diff": "^5.2.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "12.0.0",
    "material-symbols": "^0.40.2",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "4.0.379",
    "prismjs": "1.29.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.5",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.50.1",
    "vite": "^6.2.0"
