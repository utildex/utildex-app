{
  "name": "utildex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ng serve",
    "prebuild": "npm run check:integrity && npm run check:tool-ids && npm run format && npm run lint && tsx scripts/generate-sitemap.ts",
    "build": "ng build",
    "preview": "ng serve --configuration=production",
    "check:integrity": "tsx scripts/check-integrity.ts",
    "check:tool-ids": "tsx scripts/check-tool-ids.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,css,scss,json,md}\""
  },
  "dependencies": {
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/platform-browser": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@angular/service-worker": "^21.2.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@floating-ui/dom": "^1.7.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/roboto-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@types/d3": "^7.4.3",
    "codemirror": "^6.0.2",
    "d3": "^7.9.0",
    "diff": "^5.2.0",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "marked": "12.0.0",
    "material-symbols": "^0.40.2",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.4.624",
    "prismjs": "1.30.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.5",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.0.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.50.1",
    "vite": "^6.2.0"
  }
